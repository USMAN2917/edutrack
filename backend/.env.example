# ─── DATABASE ─────────────────────────────────────────────────
# Get this from Railway PostgreSQL service or Supabase
DATABASE_URL="postgresql://username:password@host:5432/edutrack"

# ─── AUTH ──────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET="your-super-secret-jwt-key-change-this-now-min-32-chars"

# ─── SERVER ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── FRONTEND URL (for CORS) ───────────────────────────────────
# Replace with your actual Vercel URL after deploy
FRONTEND_URL="https://your-app.vercel.app"
